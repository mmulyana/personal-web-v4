---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { POSTS_CONFIG } from '~/config'
import { getVisibleTutorials } from '~/lib/data'
import Layout from '~/layouts/Layout.astro'
import Pagination from '~/components/base/Pagination.astro'
import TutorialList from '~/components/tutorials/TutorialList.astro'
import PageTitle from '~/components/base/PageTitle.astro'

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const tutorials = await getVisibleTutorials()

  return paginate(tutorials, {
    pageSize: POSTS_CONFIG.postPageConfig.size, // Use post size for consistency or define tutorial size
  })
}

interface Props {
  page: Page<CollectionEntry<'tutorials'>>
}

const { page } = Astro.props

const title = 'Tutorials'
const description = 'Step-by-step guides for building modern web applications.'
const introduce = 'Deep dives into technologies, frameworks, and patterns.'
---

<Layout {title} {description}>
  <div class="relative z-[1] py-8 pb-10 px-6 sm:px-8">
    <PageTitle {title} {introduce} />
    <div class="mt-12 fade-up">
      <TutorialList tutorials={page.data} />
    </div>
    <Pagination {page} baseUrl="/tutorials" />
  </div>
</Layout>
