---
import { formatDate } from '~/lib/utils'
import type { CollectionEntry } from 'astro:content'

interface Props {
  tutorial: CollectionEntry<'tutorials'>
  index: number
}

const { tutorial, index } = Astro.props
---

<a
  href={`/tutorials/${tutorial.id}`}
  class="group relative flex flex-col gap-4 p-6 rounded-2xl border border-border/50 bg-background/50 transition-all duration-500"
  style={`animation-delay: ${index * 150}ms`}
>
  <div class="relative z-10 flex flex-col gap-3">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2 text-xs font-medium text-primary/80 uppercase tracking-widest">
        <span class="icon-[ph--graduation-cap-duotone] size-4"></span>
        Tutorial
      </div>
      <time datetime={tutorial.data.pubDate.toISOString()} class="text-xs text-muted-foreground/60 font-mono">
        {formatDate(tutorial.data.pubDate)}
      </time>
    </div>

    <div>
      <h3 class="text-lg font-bold text-foreground group-hover:text-primary transition-colors duration-300 leading-tight">
        {tutorial.data.title}
      </h3>
      {
        tutorial.data.description && (
          <p class="mt-2 text-sm text-muted-foreground/80 line-clamp-2 leading-relaxed">{tutorial.data.description}</p>
        )
      }
    </div>

    {
      tutorial.data.tags && tutorial.data.tags.length > 0 && (
        <div class="mt-auto flex flex-wrap gap-2 pt-2">
          {tutorial.data.tags.map((tag) => (
            <span class="px-2 py-0.5 rounded-full bg-muted text-[10px] font-medium text-muted-foreground border border-border/50 group-hover:border-primary/20 transition-colors">
              #{tag}
            </span>
          ))}
        </div>
      )
    }
  </div>

  <div
    class="absolute bottom-6 right-6 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-x-4 group-hover:translate-x-0"
  >
    <span class="icon-[ph--arrow-right-bold] size-5 text-primary"></span>
  </div>
</a>
